---
import type { CollectionEntry } from 'astro:content';

type Props = {
	posts: CollectionEntry<'blog'>[];
};

const { posts } = Astro.props;

const growthLabel: Record<'seed' | 'sprout' | 'branch' | 'tree', string> = {
	seed: '씨앗',
	sprout: '새싹',
	branch: '가지',
	tree: '나무',
};

/** Dot + badge tint per growth (30u30-style category colors) */
const growthStyles: Record<
	'seed' | 'sprout' | 'branch' | 'tree',
	{ dot: string; badge: string }
> = {
	seed: {
		dot: 'bg-zinc-400',
		badge: 'bg-zinc-200 text-ink border-zinc-300',
	},
	sprout: {
		dot: 'bg-emerald-500',
		badge: 'bg-emerald-100 text-emerald-900 border-emerald-300',
	},
	branch: {
		dot: 'bg-amber-500',
		badge: 'bg-amber-100 text-amber-950 border-amber-300',
	},
	tree: {
		dot: 'bg-accent',
		badge: 'bg-accent/15 text-accent border-accent/40',
	},
};

const defaultStyles = {
	dot: 'bg-ink-sub',
	badge: 'bg-sub text-ink-sub border-ink/15',
};

const fmtDate = new Intl.DateTimeFormat('en-US', {
	month: 'short',
	day: 'numeric',
	year: 'numeric',
});
---

<section class="not-prose mt-12 border-t border-ink/10 pt-10" aria-labelledby="dev-log-heading">
	<div class="mb-8 flex items-start justify-between gap-4">
		<div>
			<h2
				id="dev-log-heading"
				class="font-mono text-[11px] font-bold uppercase leading-snug tracking-[0.12em] text-ink sm:text-[12px]"
			>
				개발 기록 — development log
			</h2>
			<p class="mt-1.5 font-mono text-[10px] uppercase leading-relaxed tracking-[0.08em] text-ink-sub sm:text-[11px]">
				프로젝트 변경 사항을 기록합니다
			</p>
		</div>
		<span class="relative mt-0.5 flex h-2.5 w-2.5 shrink-0" aria-hidden="true">
			<span
				class="absolute inline-flex h-full w-full animate-ping-slow rounded-full bg-red-500 opacity-60"
			/>
			<span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-red-600 ring-2 ring-surface" />
		</span>
	</div>

	<div class="relative">
		<div class="absolute bottom-0 left-2 top-0 w-px bg-ink/15" aria-hidden="true" />
		<ol class="m-0 list-none space-y-0 p-0">
			{
				posts.map((post, i) => {
					const g = post.data.growth;
					const styles = g ? growthStyles[g] : defaultStyles;
					const dateStr = fmtDate.format(post.data.pubDate).toUpperCase();
					const isLatest = i === 0;

					return (
						<li class="relative pb-10 pl-8 last:pb-0">
							<span class="absolute left-2 top-2 z-[1] -translate-x-1/2">
								{isLatest && (
									<span
										class="absolute left-1/2 top-1/2 h-4 w-4 -translate-x-1/2 -translate-y-1/2 animate-ping-slow rounded-full bg-accent/35"
										aria-hidden="true"
									/>
								)}
								<span
									class:list={[
										'relative block h-3.5 w-3.5 shrink-0 rounded-full border-2 border-surface',
										styles.dot,
									]}
								/>
							</span>

							<div class="flex flex-wrap items-center gap-2.5">
								<time
									class="font-mono text-[10px] uppercase tabular-nums tracking-wider text-ink-sub sm:text-[11px]"
									datetime={post.data.pubDate.toISOString()}
								>
									{dateStr}
								</time>
								{g && (
									<span
										class:list={[
											'rounded border px-2 py-0.5 font-mono text-[10px] font-semibold uppercase tracking-wide',
											styles.badge,
										]}
									>
										{growthLabel[g]}
									</span>
								)}
							</div>

							<h3 class="mt-2 font-mono text-[13px] font-bold uppercase leading-snug tracking-tight text-ink sm:text-[14px]">
								{post.data.title}
							</h3>

							<p class="mt-2 font-mono text-[12px] leading-relaxed text-ink-sub sm:text-[13px]">
								{post.data.description}
							</p>

							<a
								href={`/blog/${post.slug}`}
								class="mt-3 inline-flex items-center gap-1 rounded border border-ink/15 bg-surface px-2.5 py-1 font-mono text-[11px] text-ink transition-colors hover:border-accent/40 hover:text-accent focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
							>
								<span aria-hidden="true">→</span>
								<span>글 읽기</span>
							</a>
						</li>
					);
				})
			}
		</ol>
	</div>
</section>
