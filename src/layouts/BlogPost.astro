---
import type { CollectionEntry } from 'astro:content';
import Base from './Base.astro';

type Props = {
	post: CollectionEntry<'blog'>;
};

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, growth, tags } = post.data;

const growthLabel: Record<NonNullable<typeof growth>, string> = {
	seed: '씨앗',
	sprout: '새싹',
	branch: '가지',
	tree: '나무',
};

const fmt = new Intl.DateTimeFormat('ko-KR', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<Base title={`${title} · 활자 정원`} description={description}>
	<article class="prose prose-sm prose-neutral max-w-none font-sans prose-headings:font-sans prose-headings:text-ink prose-headings:font-semibold prose-p:text-ink/90 prose-a:text-accent prose-code:font-mono prose-pre:bg-ink prose-pre:text-sub">
		<p class="text-[13px] tabular-nums text-ink-sub">
			<time datetime={pubDate.toISOString()}>{fmt.format(pubDate)}</time>
			{
				updatedDate && (
					<>
						{' '}
						· 수정 <time datetime={updatedDate.toISOString()}>{fmt.format(updatedDate)}</time>
					</>
				)
			}
		</p>
		<div class="not-prose mb-6 flex flex-wrap items-center gap-2">
			{
				growth && (
					<span class="rounded-full border border-accent/40 bg-accent/10 px-2.5 py-0.5 text-[11px] font-medium text-accent">
						{growthLabel[growth]}
					</span>
				)
			}
			{
				tags?.map((t) => (
					<span class="rounded-full bg-sub px-2.5 py-0.5 text-[11px] text-ink-sub">#{t}</span>
				))
			}
		</div>
		<h1 class="not-prose mb-1.5 text-[1.375rem] font-semibold leading-snug tracking-tight text-ink sm:text-2xl">
			{title}
		</h1>
		<p class="not-prose text-[14px] leading-relaxed text-ink-sub">{description}</p>
		<div class="mt-8 border-t border-ink/10 pt-8">
			<slot />
		</div>
	</article>
	<p class="mt-10 text-[13px]">
		<a href="/#writing" class="text-accent hover:underline">← 글 목록으로</a>
	</p>
</Base>
